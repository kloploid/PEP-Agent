# Copy to .env and fill in AZURE_OPENAI_API_KEY.
# docker compose picks these up automatically.

AZURE_OPENAI_ENDPOINT=https://taltech-agent-hackathon-2026-17.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Local embeddings (FastEmbed). Override if needed.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

QDRANT_COLLECTION=pep_docs
